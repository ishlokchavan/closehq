# Public site config
NEXT_PUBLIC_SITE_URL=https://iclose.ae
NEXT_PUBLIC_WHATSAPP_NUMBER=971501234567
NEXT_PUBLIC_CONTACT_EMAIL=start@iclose.ae
NEXT_PUBLIC_CONTACT_PHONE=+971 50 123 4567

# Cookie domain used by the referral attribution cookies (iclose_ref,
# iclose_vid). Set to .iclose.ae in production so subdomains share the
# cookie; leave empty for local dev so cookies still work on localhost.
NEXT_PUBLIC_COOKIE_DOMAIN=

# Analytics
# GA4 (loaded by components/cookie-consent.tsx after the user accepts
# analytics cookies). Tag for iClose: G-JQNMWPXKNE.
NEXT_PUBLIC_GA_ID=G-JQNMWPXKNE
NEXT_PUBLIC_META_PIXEL_ID=000000000000000

# Supabase — iclose-academy-db (used by /api/lead, /api/partner, /ref, etc.)
NEXT_PUBLIC_SUPABASE_URL=https://nnkicmfsdbfpucfcnutn.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — iClose app DB. Early-access / waitlist signups are stored here
# (public.waitlist). The route falls back to the project's public anon key,
# so these are optional overrides (e.g. after a key rotation).
WAITLIST_SUPABASE_URL=https://jvdmwvzlunmouvlvtebg.supabase.co
WAITLIST_SUPABASE_ANON_KEY=
# Service role — required for /api/partner inserts, /api/verify partner
# branch, /ref/[code] click logging, and /api/lead's partner attribution.
# All three feature paths silently no-op without this; the lead/click data
# still saves, just unattributed. NEVER expose this key client-side.
SUPABASE_SERVICE_ROLE_KEY=

# Brevo — email delivery (9,000 emails/month free)
BREVO_SMTP_USER=                          # your Brevo account email
BREVO_SMTP_KEY=                           # SMTP key from Brevo → SMTP & API → SMTP
BREVO_FROM_EMAIL=iClose <noreply.iclose@gmail.com>
# Inbox that gets admin pings on every new lead / partner / specialist signup.
NOTIFY_EMAIL=

# Calendly embed URL used by the waitlist success state.
NEXT_PUBLIC_CALENDLY_URL=

# Lead webhook (optional fallback — Make.com / Zapier / CRM)
LEAD_WEBHOOK_URL=
SPECIALIST_WEBHOOK_URL=
